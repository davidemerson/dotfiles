# Backups
backups/
*.backup

# Temporary files
*.tmp
*.swp
*~

# SSH keys (never commit these!)
dotfiles/.ssh/id_*
dotfiles/.ssh/*.pem
dotfiles/.ssh/authorized_keys

# Personal email configurations (may contain sensitive data)
dotfiles/.msmtprc
dotfiles/.muttrc

# Sublime Text session files
dotfiles/.config/sublime-text-3/Local/
dotfiles/.config/sublime-text-3/Packages/User/Package Control.cache/
dotfiles/.config/sublime-text-3/Packages/User/*.sublime-session
dotfiles/.config/sublime-text-3/Packages/User/*.sublime-workspace

# Log files
*.log

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
