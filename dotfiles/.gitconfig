[user]
	name = David Emerson
	email = d@nnix.com
	signingkey = ~/.ssh/id_d_nnix.pub
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers
[init]
	defaultBranch = main
[pull]
	ff = only
[push]
	autoSetupRemote = true
	default = simple
[fetch]
	prune = true
[rebase]
	autoStash = true
[merge]
	conflictStyle = zdiff3
[diff]
	colorMoved = default
	algorithm = histogram
[commit]
	verbose = true
# @@IF_LINUX@@
# delta is installed from apt on Linux; use it as the diff pager there.
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
	syntax-theme = ansi
# @@END_IF@@
