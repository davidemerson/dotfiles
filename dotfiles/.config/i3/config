# i3 config for OpenBSD (X11)
# Derived from sway config — same keybindings, colors, gaps.

# background + plan9 root cursor
exec --no-startup-id xsetroot -solid "#000000"
exec --no-startup-id xsetroot -cursor_name left_ptr

# autostart: notifications, clipboard-history daemon, scratchpad terminal
exec --no-startup-id dunst
exec --no-startup-id clipmenud
exec --no-startup-id st -c scratchpad -n scratchpad

# locking: xss-lock fires on X-screensaver idle, xautolock is a backup timer.
# Both call ~/.local/bin/lock (pixelated i3lock); a second invocation while
# already locked just fails to grab and exits.
exec --no-startup-id xss-lock -- lock
exec --no-startup-id xautolock -time 5 -locker lock

# modifier
set $mod Mod4
floating_modifier $mod

# font
font pango:Berkeley Mono Variable NNIX ExtraBold 16

# gaps and layout
default_orientation auto
gaps inner 4
gaps horizontal 0
smart_gaps on

# thin borders, no title bars
default_border pixel 2
default_floating_border pixel 2
hide_edge_borders smart

# scratchpad terminal + auto-float transient windows
for_window [instance="scratchpad"] move scratchpad, border pixel 2
for_window [window_role="pop-up"] floating enable
for_window [window_role="dialog"] floating enable
for_window [window_type="dialog"] floating enable

# colors
# grayscale base; light-blue border + navy frame marks the focused window
client.focused              #8fb6e0    #000000     #f2f2f2    #8fb6e0      #1f2d4d
client.unfocused            #666666    #000000     #999999    #666666      #1a1a1a
client.focused_inactive     #666666    #000000     #cccccc    #666666      #1a1a1a
client.urgent               #ffffff    #1f2d4d     #ffffff    #ffffff      #1f2d4d

# launch, lock, and volume bindings
bindsym $mod+Return exec --no-startup-id /usr/local/bin/st
bindsym $mod+b exec --no-startup-id firefox-esr
bindsym $mod+d exec --no-startup-id dmenu_run -fn 'Berkeley Mono Variable NNIX-18' -nb '#000000' -nf '#999999' -sb '#1f2d4d' -sf '#bcd6f2'
bindsym $mod+c exec --no-startup-id clipmenu
bindsym $mod+grave [instance="scratchpad"] scratchpad show
bindsym $mod+z exec --no-startup-id lock
bindsym $mod+Shift+e exec i3-nagbar -t warning -m 'Exit i3?' -B 'Yes' 'i3-msg exit'
bindsym $mod+Shift+s exec i3-nagbar -t warning -m 'Shut down?' -B 'Yes' 'doas shutdown -p now'

# screenshots (full / region) -> clipboard + ~/pictures/screenshots
bindsym Print        exec --no-startup-id shot
bindsym $mod+Print   exec --no-startup-id shot region
bindsym $mod+p       exec --no-startup-id shot
bindsym $mod+Shift+p exec --no-startup-id shot region

# volume (with dunst OSD)
bindsym $mod+m       exec --no-startup-id volnotify up
bindsym $mod+n       exec --no-startup-id volnotify down
bindsym $mod+Shift+m exec --no-startup-id volnotify mute

# window management bindings
bindsym $mod+w kill
bindsym $mod+Shift+q kill
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+j move left
bindsym $mod+Shift+k move down
bindsym $mod+Shift+i move up
bindsym $mod+Shift+l move right

# focus management bindings
bindsym $mod+j focus left
bindsym $mod+k focus down
bindsym $mod+i focus up
bindsym $mod+l focus right

# tiling, floating
bindsym $mod+h split h
bindsym $mod+v split v
bindsym $mod+Shift+space floating toggle

# workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace $ws7
bindsym $mod+8 workspace $ws8
bindsym $mod+9 workspace $ws9
bindsym $mod+0 workspace $ws10

bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5
bindsym $mod+Shift+6 move container to workspace $ws6
bindsym $mod+Shift+7 move container to workspace $ws7
bindsym $mod+Shift+8 move container to workspace $ws8
bindsym $mod+Shift+9 move container to workspace $ws9
bindsym $mod+Shift+0 move container to workspace $ws10

# resizing
mode "resize" {
    bindsym j resize shrink width 10 px or 10 ppt
    bindsym k resize grow height 10 px or 10 ppt
    bindsym i resize shrink height 10 px or 10 ppt
    bindsym l resize grow width 10 px or 10 ppt

    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

# bar
bar {
    position top
    status_command i3status
    font pango:Berkeley Mono Variable NNIX Bold 14
    colors {
        background #000000
        statusline #cccccc
        separator  #666666
        focused_workspace  #8fb6e0 #1f2d4d #ffffff
        active_workspace   #333333 #11151c #cccccc
        inactive_workspace #000000 #000000 #999999
        urgent_workspace   #ffffff #666666 #000000
    }
}
