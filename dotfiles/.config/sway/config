include /etc/sway/config.d/*

# set a background
exec swaybg --output "*" --color "#000000"

# plan9 cursor theme (installed to ~/.icons/plan9 by provision)
seat * xcursor_theme plan9 16

# input: Caps->Escape and faster key repeat (matches the OpenBSD .xinitrc)
input * {
    xkb_options caps:escape
    repeat_delay 250
    repeat_rate 30
}

# idle behavior: lock the screen at 15 min, power the display off at 30 min
# (never suspends — sleep is masked in provision.sh), and lock before any
# sleep. -f daemonizes swaylock so the timeout command returns.
exec swayidle -w timeout 900 'swaylock -f --config ~/.config/swaylock/config' timeout 1800 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' before-sleep 'swaylock -f --config ~/.config/swaylock/config'

# notification daemon (palette-themed via ~/.config/mako/config)
exec mako

# clipboard: mirror the primary selection into the clipboard (so selecting
# text in any terminal/app is pasteable everywhere with Ctrl+Shift+V, matching
# the OpenBSD st behavior), and keep a history with cliphist so a selection
# that clobbers a copied value (e.g. a 1Password field) can be recovered via
# the $mod+v picker below.
exec wl-paste --primary --watch wl-copy
exec wl-paste --watch cliphist store

# modifier definition
set $mod Mod4
floating_modifier $mod

# fonts
font pango:Berkeley Mono Variable NNIX ExtraBold 16

# gaps and layout
default_orientation auto
gaps inner 10
gaps outer 5
smart_gaps on

# colors
# grayscale base; light-blue border + navy frame marks the focused window
client.focused              #8fb6e0    #000000     #f2f2f2    #8fb6e0      #1f2d4d
client.unfocused            #666666    #000000     #999999    #666666      #1a1a1a
client.focused_inactive     #666666    #000000     #cccccc    #666666      #1a1a1a
client.urgent               #ffffff    #1f2d4d     #ffffff    #ffffff      #1f2d4d

# volume OSD: wob displays values written to a fifo. $XDG_RUNTIME_DIR is
# expanded by the shell at exec time, not by sway.
set $WOBSOCK $XDG_RUNTIME_DIR/wob.sock
exec rm -f $WOBSOCK && mkfifo $WOBSOCK && tail -f $WOBSOCK | wob

# launch, lock, and volume bindings
bindsym $mod+Return exec foot
bindsym $mod+b exec google-chrome-stable
bindsym $mod+d exec wofi --show drun
bindsym $mod+z exec swaylock --config ~/.config/swaylock/config

# screenshots (grim/slurp via ~/.local/bin/shot) -> file + clipboard
bindsym Print exec shot
bindsym Shift+Print exec shot region

# application bindings
bindsym $mod+t exec todoist
bindsym $mod+e exec flatpak run com.fastmail.Fastmail
# clipboard history picker (cliphist via wofi); $mod+c matches the OpenBSD
# i3 clipboard key. ($mod+v is vertical split, below.)
bindsym $mod+c exec cliphist list | wofi --dmenu | cliphist decode | wl-copy
# 1Password: quick access, main window, lock. Wayland requires the
# compositor to grab these (the app cannot register global hotkeys itself).
bindsym $mod+p exec 1password --quick-access
bindsym $mod+Shift+p exec 1password --show
bindsym $mod+Shift+z exec 1password --lock
bindsym $mod+Shift+e exec swaynag -t warning -m 'Exit sway?' -B 'Yes' 'swaymsg exit'
bindsym $mod+Shift+s exec swaynag -t warning -m 'Shut down?' -B 'Yes' 'systemctl poweroff'
bindsym $mod+m exec pamixer -i 5 && pamixer --get-volume > $WOBSOCK
bindsym $mod+n exec pamixer -d 5 && pamixer --get-volume > $WOBSOCK

# window management bindings
bindsym $mod+Shift+q kill
bindsym $mod+w kill
bindsym $mod+Shift+c reload
# sway has no `restart` (an i3-ism); reload is the closest equivalent.
bindsym $mod+Shift+r reload
bindsym $mod+Shift+j move left
bindsym $mod+Shift+k move down
bindsym $mod+Shift+i move up
bindsym $mod+Shift+l move right

# focus management bindings
bindsym $mod+j focus left
bindsym $mod+k focus down
bindsym $mod+i focus up
bindsym $mod+l focus right

# tiling, floating
bindsym $mod+h split h
bindsym $mod+v split v
bindsym $mod+Shift+space floating toggle

# workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace $ws7
bindsym $mod+8 workspace $ws8
bindsym $mod+9 workspace $ws9
bindsym $mod+0 workspace $ws10

bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5
bindsym $mod+Shift+6 move container to workspace $ws6
bindsym $mod+Shift+7 move container to workspace $ws7
bindsym $mod+Shift+8 move container to workspace $ws8
bindsym $mod+Shift+9 move container to workspace $ws9
bindsym $mod+Shift+0 move container to workspace $ws10

# resizing
mode "resize" {
    bindsym j resize shrink width 10 px or 10 ppt
    bindsym k resize grow height 10 px or 10 ppt
    bindsym i resize shrink height 10 px or 10 ppt
    bindsym l resize grow width 10 px or 10 ppt

    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

# bar
exec waybar
