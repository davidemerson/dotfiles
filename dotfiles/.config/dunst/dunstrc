[global]
    monitor = 0
    follow = none
    width = 380
    height = (0, 140)
    origin = top-right
    offset = (16, 16)
    notification_limit = 5
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    indicate_hidden = yes
    transparency = 0
    separator_height = 2
    padding = 10
    horizontal_padding = 12
    frame_width = 2
    frame_color = "#1f2d4d"
    separator_color = frame
    sort = yes
    font = Berkeley Mono Variable NNIX 11
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    icon_position = off
    sticky_history = yes
    history_length = 20
    corner_radius = 0
    dmenu = /usr/local/bin/dmenu -p dunst:
    browser = /usr/local/bin/chrome
    title = Dunst
    class = Dunst
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#000000"
    foreground = "#999999"
    frame_color = "#666666"
    timeout = 4

[urgency_normal]
    background = "#000000"
    foreground = "#cccccc"
    frame_color = "#1f2d4d"
    timeout = 6

[urgency_critical]
    background = "#1f2d4d"
    foreground = "#ffffff"
    frame_color = "#8fb6e0"
    timeout = 0
