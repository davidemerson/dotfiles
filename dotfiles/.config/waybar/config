
{
    "position": "top", // Waybar position (top|bottom|left|right)
    "modules-left": [
    	"sway/workspaces",
    	"sway/mode",
    	],
    "modules-center": [],
    "modules-right": [
    	"network",
    	"custom/netgraph",
    	"cpu",
    	"custom/loadgraph",
    	"memory",
    	"clock#est",
    	"clock#utc",
    	"tray",
    	],
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>",
    },
    "tray": {
        "spacing": 10,
    },
    // Two clocks, each labeled so it's clear which zone is which. Date is
    // shown once, on the EST clock, in the existing Y-M-D format.
    "clock#est": {
    	"interval": 1,
    	"timezone": "America/New_York",
        "format": "EST {:%Y-%m-%d %H:%M:%S}",
    },
    "clock#utc": {
    	"interval": 1,
    	"timezone": "UTC",
        "format": "UTC {:%H:%M:%S}",
    },
    "cpu": {
        "format": "CPU: {usage}% ",
    },
    // Rolling load histogram (~last minute): 20 samples at 3s each, drawn as
    // an on-brand gray->blue block sparkline by loadgraph.sh.
    "custom/loadgraph": {
    	"exec": "sh $HOME/.config/waybar/loadgraph.sh",
    	"interval": 3,
    	"format": "load {}",
    	"tooltip": false,
    },
    // Two rolling throughput histograms (~last half minute): 10 samples at 3s
    // each, summed across physical interfaces. Down arrow = in, up = out, drawn
    // by netgraph.sh at half the width of the load bar.
    "custom/netgraph": {
    	"exec": "sh $HOME/.config/waybar/netgraph.sh",
    	"interval": 3,
    	"format": "net {}",
    	"tooltip": false,
    },
    "memory": {
        "format": "RAM: {}% ",
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%)",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr}",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "Disconnected ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
    },
}
