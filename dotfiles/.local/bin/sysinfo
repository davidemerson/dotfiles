#!/bin/sh
# Append CPU (cores/sockets) and per-device disk usage to the login fetch,
# styled like pfetch: blue label at column 1, value at column 9. Cross-OS.

_fl() { printf ' \033[1;34m%s\033[0m\033[9G\033[37m%s\033[0m\n' "$1" "$2"; }
_dk() { printf ' \033[1;34m%s\033[0m\033[9G\033[37m%-11s %s\033[0m\n' "$1" "$2" "$3"; }

cores=""; sockets=""; threads=""
case "$(uname -s)" in
    OpenBSD)
        threads=$(sysctl -n hw.ncpu 2>/dev/null)
        sockets=$(dmesg | sed -n 's/.*package \([0-9][0-9]*\).*/\1/p' | sort -u | grep -c .)
        cores=$(dmesg | sed -n 's/.* core \([0-9][0-9]*\), package \([0-9][0-9]*\)/\2-\1/p' | sort -u | grep -c .)
        [ "${sockets:-0}" -ge 1 ] 2>/dev/null || sockets=1
        [ "${cores:-0}" -ge 1 ] 2>/dev/null || cores=$threads
        ;;
    Linux)
        sockets=$(lscpu 2>/dev/null | awk -F: '/^Socket\(s\)/{gsub(/ /,"",$2);print $2}')
        cps=$(lscpu 2>/dev/null | awk -F: '/^Core\(s\) per socket/{gsub(/ /,"",$2);print $2}')
        threads=$(nproc 2>/dev/null)
        [ -n "$sockets" ] && [ -n "$cps" ] && cores=$((sockets * cps))
        [ -n "$cores" ] || cores=$threads
        [ -n "$sockets" ] || sockets=1
        ;;
    Darwin)
        sockets=$(sysctl -n hw.packages 2>/dev/null)
        cores=$(sysctl -n hw.physicalcpu 2>/dev/null)
        threads=$(sysctl -n hw.logicalcpu 2>/dev/null)
        ;;
esac

plural=""; [ "${sockets:-1}" = "1" ] || plural="s"
if [ -n "$threads" ] && [ "$threads" != "$cores" ]; then
    _fl cpu "$cores cores ($threads threads), $sockets socket$plural"
else
    _fl cpu "$cores cores, $sockets socket$plural"
fi

# Disk: one row per mounted physical device. Used/Size and capacity.
df -h 2>/dev/null | awk '$1 ~ /^\/dev\//{print $NF, $3"/"$2, "("$5")"}' | {
    first=1
    while read -r mnt usz cap; do
        if [ "$first" = 1 ]; then _dk disk "$mnt" "$usz $cap"; first=0
        else _dk "" "$mnt" "$usz $cap"; fi
    done
}
