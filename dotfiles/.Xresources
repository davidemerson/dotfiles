! X resources — crisp Xft rendering for Berkeley Mono.
! Merged by ~/.xinitrc on OpenBSD (xrdb -merge). Harmless elsewhere.
Xft.antialias: 1
Xft.hinting:   1
Xft.hintstyle: hintslight
Xft.rgba:      rgb
Xft.lcdfilter: lcddefault
! 96 is the safe default; bump to 144 on a HiDPI panel.
Xft.dpi:       96

! plan9 cursor theme (native size 16; bump to 24 if you want it larger)
Xcursor.theme: plan9
Xcursor.size:  16
